generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================================
// 系統マスタ
// ========================================

model ParentLineage {
  id            Int            @id @default(autoincrement())
  name          String         @unique
  childLineages ChildLineage[]
  createdAt     DateTime       @default(now())
}

model ChildLineage {
  id              Int            @id @default(autoincrement())
  name            String         @unique
  parentLineageId Int
  parentLineage   ParentLineage  @relation(fields: [parentLineageId], references: [id])
  stallions       Stallion[]
  createdAt       DateTime       @default(now())
}

// ========================================
// ニックス相性
// ========================================

model NicksRelation {
  id         Int @id @default(autoincrement())
  lineageAId Int
  lineageBId Int
  level      Int // 1-3

  @@unique([lineageAId, lineageBId])
}

// ========================================
// 種牡馬
// ========================================

model Stallion {
  id             Int            @id @default(autoincrement())
  name           String         @unique
  childLineageId Int
  childLineage   ChildLineage   @relation(fields: [childLineageId], references: [id])
  speed          Int?
  stamina        Int?
  power          Int?
  guts           Int?
  wisdom         Int?
  health         Int?
  memo           String?
  factors        Factor[]
  pedigreeAsAncestor PedigreeEntry[] @relation("ancestor")
  foalsAsSire    Foal[]         @relation("sire")
  racehorsesAsSire Racehorse[]  @relation("racehorseSire")
  breedingPlans  BreedingPlan[] @relation("planStallion")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

// ========================================
// 繁殖牝馬
// ========================================

model Mare {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  lineage   String
  speed     Int?
  stamina   Int?
  memo      String?
  factors   Factor[]
  foalsAsDam Foal[]  @relation("dam")
  racehorsesAsDam Racehorse[] @relation("racehorseDam")
  breedingPlans BreedingPlan[] @relation("planMare")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ========================================
// 因子
// ========================================

model Factor {
  id         Int        @id @default(autoincrement())
  type       FactorType
  stallionId Int?
  stallion   Stallion?  @relation(fields: [stallionId], references: [id], onDelete: Cascade)
  mareId     Int?
  mare       Mare?      @relation(fields: [mareId], references: [id], onDelete: Cascade)
}

enum FactorType {
  SPEED
  STAMINA
  POWER
  TENACITY
  AGILITY
  HEALTH
  SPIRIT
  WISDOM
  FAMOUS_SIRE
  GREAT_SIRE
}

// ========================================
// 血統表
// ========================================

model PedigreeEntry {
  id         Int      @id @default(autoincrement())
  horseType  String   // "stallion" or "mare"
  horseId    Int
  ancestorId Int
  ancestor   Stallion @relation("ancestor", fields: [ancestorId], references: [id])
  generation Int      // 1=父/母, 2=祖父, etc.
  position   String   // "F","M","FF","FM","MF","MM" etc.

  @@index([horseType, horseId, generation])
}

// ========================================
// 幼駒
// ========================================

model Foal {
  id             Int        @id @default(autoincrement())
  name           String?
  birthYear      Int
  gender         Gender
  sireId         Int?
  sire           Stallion?  @relation("sire", fields: [sireId], references: [id])
  damId          Int?
  dam            Mare?      @relation("dam", fields: [damId], references: [id])
  kappaMark      EvalMark   @default(NONE)
  mikaMark       EvalMark   @default(NONE)
  bodyComment    String?
  growthType     GrowthType?
  estimatedSpeed Int?
  memo           String?
  flags          FoalFlag[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

enum Gender {
  MALE
  FEMALE
}

enum EvalMark {
  DOUBLE_CIRCLE
  CIRCLE
  TRIANGLE
  NONE
}

enum GrowthType {
  SUPER_EARLY
  EARLY
  NORMAL
  LATE
  SUPER_LATE
}

// ========================================
// フラグ管理
// ========================================

model FoalFlag {
  id          Int      @id @default(autoincrement())
  foalId      Int
  foal        Foal     @relation(fields: [foalId], references: [id], onDelete: Cascade)
  type        FlagType
  description String?
  targetDate  String?

  @@index([foalId])
}

enum FlagType {
  KEEP          // 自己所有
  CLUB          // クラブへ回す
  SALE_AUGUST   // 8月セリで売却
  SALE_OVERSEAS // 12月海外セリで売却
  WATCH         // 様子見
}

// ========================================
// ウイポカレンダー・TODO
// ========================================

model GameEvent {
  id          Int      @id @default(autoincrement())
  targetYear  Int?     // 特定の年専用のイベント（nullなら毎年）
  targetMonth Int      // 1-12
  targetWeek  Int      // 1-4
  title       String
  description String?
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ========================================
// マイ牧場史・G1ギャラリー
// ========================================

model GalleryEntry {
  id          Int      @id @default(autoincrement())
  title       String
  imageUrl    String?  // 画像のローカル相対パスまたはURL
  content     String
  eventDate   String?  // 例: "2026年11月4週"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ========================================
// 配合計画
// ========================================

model BreedingPlan {
  id         Int        @id @default(autoincrement())
  year       Int
  stallionId Int
  stallion   Stallion   @relation("planStallion", fields: [stallionId], references: [id])
  mareId     Int
  mare       Mare       @relation("planMare", fields: [mareId], references: [id])
  memo       String?
  status     PlanStatus @default(PLANNED)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

enum PlanStatus {
  PLANNED
  COMPLETED
  CANCELLED
}

// ========================================
// 現役馬
// ========================================

model Racehorse {
  id             Int          @id @default(autoincrement())
  name           String
  birthYear      Int?
  gender         Gender
  sireId         Int?
  sire           Stallion?    @relation("racehorseSire", fields: [sireId], references: [id])
  damId          Int?
  dam            Mare?        @relation("racehorseDam", fields: [damId], references: [id])
  growthType     GrowthType?
  surface        Surface?
  distanceMin    Int?
  distanceMax    Int?
  temperament    Temperament? // 気性
  runningStyle   RunningStyle? // 脚質
  spirit         EvalMark     @default(NONE) // 精神力などを評価記号代用
  health         EvalMark     @default(NONE) // 健康
  // 成績
  starts         Int?         // 出走数
  wins           Int?         // 勝利数
  g1Wins         Int?         // G1勝利数
  // 能力値（S / A+ / A / B+ / B / C+ / C / D+ / D / E+ / E / F）
  speed          String?
  stamina        String?
  power          String?
  guts           String?
  intelligence   String?
  autoComment    String?
  aiComment      String?
  memo           String?
  status         HorseStatus  @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

enum Surface {
  TURF
  DIRT
  BOTH
}

enum HorseStatus {
  ACTIVE
  RETIRED
}

enum Temperament {
  FIERCE       // 激
  ROUGH        // 荒
  NORMAL       // 普通
  MILD         // 大人
  SUPER_MILD   // 超
}

enum RunningStyle {
  GREAT_ESCAPE // 大逃げ
  ESCAPE       // 逃げ
  LEADER       // 先行
  CLOSER       // 差し
  CHASER       // 追込
  VERSATILE    // 自在
}

